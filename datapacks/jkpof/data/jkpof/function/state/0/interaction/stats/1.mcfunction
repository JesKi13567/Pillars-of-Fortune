$dialog show @s {type: "notice", title: {text: "$(name)", color: "white", bold: true}, body: [{type: "plain_message", contents: [{text: "\
$(txt_round): $(round)  $(txt_win): $(win)\n\n\
$(txt_kill): $(kill)  $(txt_kill_1st): $(kill_1st)\n\n\
$(txt_death_all): $(death_all)  $(txt_death_suicide): $(death_suicide)  $(txt_death_1st): $(death_1st)\n\n\
$(txt_king_kill): $(king_kill)  $(txt_king_live): $(king_live)\
"}]}]}
