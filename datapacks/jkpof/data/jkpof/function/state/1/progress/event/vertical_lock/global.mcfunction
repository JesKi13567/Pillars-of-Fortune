execute if score #event_time jkpof.int matches 1.. at @e[type=marker, tag=jkpof_vertical_lock] run fill -24 ~ -24 24 ~ 24 barrier replace #replaceable
execute if score #event_time jkpof.int matches 0 at @e[type=marker, tag=jkpof_vertical_lock] run fill -24 ~ -24 24 ~ 24 air replace barrier
execute if score #event_time jkpof.int matches 0 run kill @e[type=marker, tag=jkpof_vertical_lock]

execute if score #event_time jkpof.int matches 60 run tellraw @a [{storage: "jk:pof", interpret: true, nbt: "txt.POF", color: "yellow"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.vertical_lock.name", color: "aqua"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.will_end_in.p1"}, {text: "3", color: "white"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.seconds", color: "white"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.will_end_in.p2"}]
execute if score #event_time jkpof.int matches 40 run tellraw @a [{storage: "jk:pof", interpret: true, nbt: "txt.POF", color: "yellow"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.vertical_lock.name", color: "aqua"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.will_end_in.p1"}, {text: "2", color: "white"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.seconds", color: "white"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.will_end_in.p2"}]
execute if score #event_time jkpof.int matches 20 run tellraw @a [{storage: "jk:pof", interpret: true, nbt: "txt.POF", color: "yellow"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.vertical_lock.name", color: "aqua"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.will_end_in.p1"}, {text: "1", color: "white"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.seconds", color: "white"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.will_end_in.p2"}]
execute if score #event_time jkpof.int matches 0 run tellraw @a [{storage: "jk:pof", interpret: true, nbt: "txt.POF", color: "yellow"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.vertical_lock.name", color: "aqua"}, {storage: "jk:pof", interpret: true, nbt: "txt.event.global.stage_ended"}]
